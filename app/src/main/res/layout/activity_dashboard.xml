<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp"
    tools:context=".DashboardActivity">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="FocusFlow Dashboard"
        android:textStyle="bold"
        android:textSize="26sp"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:id="@+id/tvGreeting"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hello!"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="10dp"/>

    <EditText
        android:id="@+id/etName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter Your Name"
        android:inputType="textPersonName"/>

    <Button
        android:id="@+id/btnSaveName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Save Name"
        android:layout_marginTop="10dp"/>

    <TextView
        android:id="@+id/tvStreak"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Streak: 0"
        android:textStyle="bold"
        android:textSize="18sp"
        android:layout_marginTop="20dp"/>

    <TextView
        android:id="@+id/tvWeekly"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Weekly Minutes: 0"
        android:textStyle="bold"
        android:textSize="18sp"
        android:layout_marginTop="10dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Today's Tasks"
        android:textStyle="bold"
        android:textSize="20sp"
        android:layout_marginTop="20dp"/>

    <ListView
        android:id="@+id/lvTodayTasks"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:layout_marginTop="10dp"/>

    <Button
        android:id="@+id/btnStudyPlanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Study Planner"
        android:layout_marginTop="20dp"/>

    <Button
        android:id="@+id/btnFocusMode"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Focus Mode"
        android:layout_marginTop="10dp"/>

    <Button
        android:id="@+id/btnResources"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Resources"
        android:layout_marginTop="10dp"/>

    <Button
        android:id="@+id/btnProfile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Profile"
        android:layout_marginTop="10dp"/>

</LinearLayout>